{
  "name": "file-guardian",
  "version": "1.0.0",
  "description": "企业级文件自动备份与对比工具",
  "main": "dist/main/main.js",
  "author": "FileGuardian Team",
  "license": "MIT",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build && tsc -p tsconfig.main.json",
    "build:main": "tsc -p tsconfig.main.json",
    "start": "electron .",
	  "des": "concurrently  \"npm run dev\" \"npm start\"",
    "pack": "npm run build && electron-builder --dir",
    "dist": "npm run build && electron-builder",
    "dist:win": "npm run build && electron-builder --win",
    "dist:mac": "npm run build && electron-builder --mac",
    "dist:linux": "npm run build && electron-builder --linux"
  },
  "dependencies": {
    "@parcel/watcher": "^2.5.1",
    "diff-match-patch": "^1.0.5",
    "electron-store": "^8.1.0",
    "fs-extra": "^11.2.0",
    "pinia": "^2.1.7",
    "uuid": "^9.0.1",
    "vue": "^3.4.21",
    "vue-router": "^4.3.0",
	"vite-plugin-electron": "^0.15.5"
  },
  "devDependencies": {
    "@types/diff-match-patch": "^1.0.36",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^20.11.24",
    "@types/uuid": "^9.0.8",
    "@vitejs/plugin-vue": "^5.0.4",
    "concurrently": "^9.2.1",
    "electron": "^29.4.6",
    "electron-builder": "^24.13.3",
    "typescript": "^5.3.3",
    "vite": "^5.1.4",
    "vue-tsc": "^2.0.6"
  },
  "build": {
    "appId": "com.fileguardian.app",
    "productName": "FileGuardian",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "build/icon.ico"
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "build/icon.icns"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "icon": "build/icons"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}

